# mcp-zus — example environment configuration

# --- KEDU / EWD (płatnikowy kanał) ---
# NIP płatnika (10 cyfr)
ZUS_PAYER_NIP=
# Identyfikator zewnętrzny (numer ZUS — IDP) jeśli posiadasz
ZUS_PAYER_IDP=

# --- EWD endpoint (ustawiany przy akredytacji u ZUS) ---
ZUS_EWD_WSDL_URL=
ZUS_EWD_BASIC_USER=
ZUS_EWD_BASIC_PASS=

# --- OK-WUD (instytucje uprawnione) ---
ZUS_OKWUD_WSDL_URL=https://pue.zus.pl:8100/ws/zus.channel.pub:wsdlPub
ZUS_OKWUD_BASIC_USER=
ZUS_OKWUD_BASIC_PASS=
# Kod instytucji wnioskodawcy (np. KS, S, NFZ, OPS — patrz okwud.kody_instytucji)
ZUS_OKWUD_RODZAJ_KOD=

# --- ePUAP ---
ZUS_EPUAP_WSDL_URL=
ZUS_EPUAP_PODMIOT_ID=
ZUS_EPUAP_TARGET_ESP=/ZUS/esp

# --- PUE Session Companion (browser-attached) ---
# Chrome z --remote-debugging-port uruchamiany jest po stronie usera.
# MCP łączy się przez CDP do tego portu.
PUE_CDP_URL=http://localhost:9222

# --- BYO key (User-side signing) ---
# MCP NIE czyta kluczy prywatnych — to jest tylko ścieżka do certyfikatu publicznego dla embeddowania.
ZUS_PUBLIC_CERT_PATH=

# --- Logging ---
MCP_ZUS_LOG_LEVEL=INFO
